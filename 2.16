#include <ArduinoIoTCloud.h>
#include <Arduino_ConnectionHandler.h>
#include <Arduino_NetworkConfigurator.h>
#include "configuratorAgents/agents/BLEAgent.h"
#include "configuratorAgents/agents/SerialAgent.h"

String cloud_stressState;
float cloud_EC_mS;
float cloud_HRT;
float cloud_MFC_mV;
float cloud_ORP_mV;
float cloud_pH;
float cloud_Q_kombucha_mL;
float cloud_Q_spir_mL;
float cloud_Q_urine_mL;
float cloud_Temp_C;
int cloud_holdRemaining_min;
int cloud_stressCycle;
bool cloud_emergency;
bool cloud_gateOn;

KVStore kvStore;
BLEAgentClass BLEAgent;
SerialAgentClass SerialAgent;
WiFiConnectionHandler ArduinoIoTPreferredConnection; 
NetworkConfiguratorClass NetworkConfigurator(ArduinoIoTPreferredConnection);

void initProperties(){
  NetworkConfigurator.addAgent(BLEAgent);
  NetworkConfigurator.addAgent(SerialAgent);
  NetworkConfigurator.setStorage(kvStore);
  // For changing the default reset pin uncomment and set your preferred pin. Use DISABLE_PIN for disabling the reset procedure.
  //NetworkConfigurator.setReconfigurePin(your_pin);
  ArduinoCloud.setConfigurator(NetworkConfigurator);

  ArduinoCloud.addProperty(cloud_stressState, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_EC_mS, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_HRT, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_MFC_mV, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_ORP_mV, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_pH, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_Q_kombucha_mL, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_Q_spir_mL, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_Q_urine_mL, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_Temp_C, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_holdRemaining_min, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_stressCycle, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_emergency, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(cloud_gateOn, READ, ON_CHANGE, NULL);

}
