}

// ================================================================
// PUMP RUNNER — UNCHANGED
// ================================================================
void runPump_mL(int pin, float mL, float mL_per_sec, const char* name) {
  if (mL <= 0.0f) {
    Serial.print(F("  SKIP "));
    Serial.print(name);
    Serial.println(F(": 0.000 mL"));
    return;
  }

  float seconds = mL / mL_per_sec;
  unsigned long ms = (unsigned long)(seconds * 1000.0f);
  if (ms < 30) ms = 30;

  Serial.print(F("  RUN "));
  Serial.print(name);
  Serial.print(F(": "));
  Serial.print(mL, 3);
  Serial.print(F(" mL ("));
  Serial.print(ms);
  Serial.println(F(" ms)"));

  digitalWrite(pin, HIGH);
  delay(ms);
  digitalWrite(pin, LOW);
  delay(100);
}

void executeDose(const DoseVolumes& d) {
  Serial.println(F("--- TANK 1 DOSING ---"));
  runPump_mL(PUMP_URINE_T1,    d.Q_urine_mL,    ML_PER_SEC_URINE_T1,    "URINE (D8)");
  runPump_mL(PUMP_KOMBUCHA_T1, d.Q_kombucha_mL, ML_PER_SEC_KOMBUCHA_T1, "PHOSPHORIC (D2)");
  runPump_mL(PUMP_ACETATE_T1,  d.Q_acetate_mL,  ML_PER_SEC_ACETATE_T1,  "ACETATE (D4)");
  Serial.println(F("--- DONE ---"));
}

// ================================================================
// STATUS PRINT
// ================================================================
void printStatus(const SensorData& s, float hrt, bool gateOn, int idx) {
  unsigned long sec = millis() / 1000;

  Serial.print(sec);
  Serial.print(F("s | idx="));
  Serial.print(idx);
  Serial.print(F(" | Gate="));
  Serial.print(gateOn ? F("ON ") : F("OFF "));
  Serial.print(F("| "));
  Serial.print(getPhaseName());

  Serial.print(F(" | pH="));
  Serial.print(s.pH, 2);
  Serial.print(F(" EC="));
  Serial.print(s.EC_mS, 2);
  Serial.print(F("mS"));

  Serial.print(F(" | ORP="));
  if (s.ORP_valid) { Serial.print(s.ORP_mV, 0); Serial.print(F("mV")); }
  else             { Serial.print(F("--")); }

  Serial.print(F(" MFC="));
  if (s.MFC_valid) { Serial.print(s.MFC_mV, 0); Serial.print(F("mV")); }
  else             { Serial.print(F("--")); }

  Serial.print(F(" | x̂=["));
  for (int i = 0; i < 4; i++) {
    Serial.print(x_hat[i], 2);
    if (i < 3) Serial.print(F(","));
  }
  Serial.print(F("]"));

  Serial.print(F(" | ŷ=[ORP="));
  Serial.print(pred_ORP, 0);
  Serial.print(F(" MFC="));
  Serial.print(pred_MFC, 0);
  Serial.print(F("]"));

  Serial.print(F(" | HRT="));
  Serial.print(hrt, 1);

  Serial.print(F(" | Temp="));
  if (isnan(s.Temp_C)) Serial.println(F("NA"));
  else { Serial.print(s.Temp_C, 1); Serial.println(F("C")); }
}

// ================================================================
// SETUP
// ================================================================
void setup() {
  Serial.begin(115200);
  delay(1500);

  analogReadResolution(12);

  pinMode(PUMP_URINE_T1, OUTPUT);
  pinMode(PUMP_KOMBUCHA_T1, OUTPUT);
  pinMode(PUMP_ACETATE_T1, OUTPUT);
  allPumpsOff();

  pinMode(RELAY_UNUSED_1, OUTPUT);
  pinMode(RELAY_UNUSED_2, OUTPUT);
  forceUnusedRelaysOff();

  pinMode(RELAY_MFC_GATE, OUTPUT);
  digitalWrite(RELAY_MFC_GATE, RELAY_OFF);

  tempBus1.begin();
  tempBus1.setWaitForConversion(true);
  tempBus1.setResolution(12);

  // ---- ARDUINO IoT CLOUD INIT ----
  initProperties();
  ArduinoCloud.begin(ArduinoIoTPreferredConnection);
  setDebugMessageLevel(2);
  ArduinoCloud.printDebugInfo();

  Serial.println(F(""));
  Serial.println(F("================================================"));
  Serial.println(F("  TANK 1 - LQR OBSERVER CONTROLLER"));
  Serial.println(F("  Phase 1: P-control pH → [6.5, 8.0]"));
  Serial.println(F("  Phase 2: LQR (target ORP=-173, MFC=401)"));
  Serial.println(F("  Model: 4-state, 1-min steps"));
  Serial.println(F("  R = [18000, 1800, 15000]"));
  Serial.println(F("  Pumps: URINE=D8, PHOSPHORIC=D2, ACETATE=D4"));
  Serial.println(F("  MFC Gate Relay: D3"));
  Serial.println(F("  Dose every 60s | Status every 2s"));
  Serial.println(F("================================================"));
  Serial.println(F(""));

  Serial.println(F("CSVHEADER,Time_s,SampleIdx,GateOn,Phase,DoseCount,pH,EC_mS,ORP_mV,MFC_mV,Temp_C,predORP,predMFC,HRT,h1,h2,Q_urine,Q_kombucha,Q_acetate"));

  controlPhase      = PHASE_PH_STABILIZE;
  pH_stable_counter = 0;
  observer_initialized = false;

  lastDoseTime      = millis();
  lastStatusTime    = millis();
  lastSampleStepMs  = millis();
  lastCloudUpdateMs = millis();
  sampleIndex       = 0;
}

// ================================================================
// MAIN LOOP
// ================================================================
void loop() {
  ArduinoCloud.update();
  forceUnusedRelaysOff();

  unsigned long now = millis();

  // ---- Advance 1Hz sample index ----
  if (now - lastSampleStepMs >= SAMPLE_STEP_MS) {
    lastSampleStepMs += SAMPLE_STEP_MS;
    sampleIndex++;
    if (sampleIndex >= TOTAL_POINTS) sampleIndex = 0;
  }

  // Gate OFF for ORP samples (0..4), ON for MFC samples (5..9)
  bool gateOn = (sampleIndex >= ORP_POINTS);
  digitalWrite(RELAY_MFC_GATE, gateOn ? RELAY_ON : RELAY_OFF);

  // ---- Status every 2 seconds ----
  if (now - lastStatusTime >= STATUS_INTERVAL_MS) {
    bool doORP = !gateOn;
    bool doMFC =  gateOn;

    SensorData s = readTank1Sensors(doORP, doMFC);

    latest_pH    = s.pH;
    latest_EC_mS = s.EC_mS;
    if (s.ORP_valid) latest_ORP_mV = s.ORP_mV;
    if (s.MFC_valid) latest_MFC_mV = s.MFC_mV;
    if (!isnan(s.Temp_C)) latest_Temp_C = s.Temp_C;
    latest_gateOn = gateOn;

    printStatus(s, latest_HRT, gateOn, sampleIndex);

    // CSV output
    Serial.print(F("DATA,"));
    Serial.print((unsigned long)(now / 1000));
    Serial.print(F(",")); Serial.print(sampleIndex);
    Serial.print(F(",")); Serial.print(gateOn ? 1 : 0);
    Serial.print(F(",")); Serial.print(getPhaseName());
    Serial.print(F(",")); Serial.print(doseCount);
    Serial.print(F(",")); Serial.print(s.pH, 3);
    Serial.print(F(",")); Serial.print(s.EC_mS, 3);
    Serial.print(F(","));
    if (s.ORP_valid) Serial.print(s.ORP_mV, 1); else Serial.print(F("NA"));
    Serial.print(F(","));
    if (s.MFC_valid) Serial.print(s.MFC_mV, 1); else Serial.print(F("NA"));
    Serial.print(F(","));
    if (isnan(s.Temp_C)) Serial.print(F("NA")); else Serial.print(s.Temp_C, 2);
    Serial.print(F(",")); Serial.print(pred_ORP, 1);
    Serial.print(F(",")); Serial.print(pred_MFC, 1);
    Serial.print(F(",")); Serial.print(latest_HRT, 1);
    Serial.print(F(",")); Serial.print(x_hat[2], 3);
    Serial.print(F(",")); Serial.print(x_hat[3], 3);
    Serial.print(F(",")); Serial.print(latest_Q_urine, 4);
    Serial.print(F(",")); Serial.print(latest_Q_kombucha, 4);
    Serial.print(F(",")); Serial.println(latest_Q_acetate, 4);

    lastStatusTime = now;
  }

  // ---- Cloud sync every 5 seconds ----
  if (now - lastCloudUpdateMs >= CLOUD_UPDATE_INTERVAL_MS) {
    syncToCloud(now);
    lastCloudUpdateMs = now;
  }

  // ════════════════════════════════════════════
  // ████  DOSE EVERY 60 SECONDS  ████
  // ════════════════════════════════════════════
  if (now - lastDoseTime >= DOSE_INTERVAL_MS) {
    digitalWrite(RELAY_MFC_GATE, RELAY_OFF);

    Serial.println(F(""));
    Serial.println(F("========================================"));
    Serial.print(F("======= DOSING | PHASE: "));
    Serial.print(getPhaseName());
    Serial.print(F(" | Dose #"));
    Serial.print(doseCount);
    Serial.println(F(" ======="));
    Serial.println(F("========================================"));

    // Read sensors
    SensorData s = readTank1Sensors(true, false);
    float dT = isnan(s.Temp_C) ? 0.0f : (s.Temp_C - T_ref);

    // Update observer with current measurements and LAST dose
    float u_last[3] = {latest_Q_urine, latest_Q_acetate, latest_Q_kombucha};
    observerUpdate(s.EC_mS, s.pH, u_last, dT);

    // Compute new dose
    DoseVolumes d = computeLQRDose(dT);

    // Print state
    Serial.print(F("  pH="));     Serial.print(s.pH, 3);
    Serial.print(F(" EC="));      Serial.print(s.EC_mS, 3);
    Serial.print(F(" Temp="));    
    if (isnan(s.Temp_C)) Serial.print(F("NA")); else Serial.print(s.Temp_C, 1);
    Serial.print(F(" | Phase: ")); Serial.println(getPhaseName());

    Serial.print(F("  x̂ = ["));
    for (int i = 0; i < 4; i++) {
      Serial.print(x_hat[i], 3);
      if (i < 3) Serial.print(F(", "));
    }
    Serial.println(F("]"));

    Serial.print(F("  Predicted: ORP="));
    Serial.print(pred_ORP, 1);
    Serial.print(F(" mV  MFC="));
    Serial.print(pred_MFC, 1);
    Serial.println(F(" mV"));

    Serial.print(F("  Dose (mL): urine="));
    Serial.print(d.Q_urine_mL, 4);
    Serial.print(F(" phosphoric="));
    Serial.print(d.Q_kombucha_mL, 4);
    Serial.print(F(" acetate="));
    Serial.print(d.Q_acetate_mL, 4);
    Serial.print(F(" total="));
    Serial.println(d.Q_total_mL, 4);

    Serial.print(F("  HRT="));
    Serial.print(d.HRT, 1);
    Serial.println(F(" h"));

    // Store for cloud + next observer update
    latest_Q_urine    = d.Q_urine_mL;
    latest_Q_kombucha = d.Q_kombucha_mL;
    latest_Q_acetate  = d.Q_acetate_mL;
    latest_HRT        = d.HRT;
    latest_emergency  = false;

    syncToCloud(now);
    ArduinoCloud.update();

    // Execute pumps
    executeDose(d);

    ArduinoCloud.update();

    doseCount++;
    Serial.print(F("  Dose count: "));
    Serial.println(doseCount);
    Serial.println(F("========================================"));
    Serial.println(F(""));

    lastDoseTime = millis();
  }
}
