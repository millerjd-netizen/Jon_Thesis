/*
 * ================================================================
 * ANAEROBIC DIGESTER - TANK 1 - CONSTANT FLOW RATE
 * Arduino GIGA R1 WiFi
 *
 * Simple constant dosing at HRT = 12 hours.
 * No controller. No observer. No phases.
 *
 * Sensors: pH (A0), ORP (A1), EC (A2), MFC (A3), Temp (D10)
 * Pumps:   Urine (D8), Acetate (D4) — alternate every 5 min
 *          Phosphoric/Kombucha (D2)  — HELD OFF always
 * MFC Gate Relay: D3
 * Arduino IoT Cloud: 14 variables
 *
 * CALIBRATION:
 *   pH:  pH7 buffer → 1.2355V, pH4 buffer → 1.6335V
 *        M=-7.5375, B=16.3125
 *        pH=0 floor at V>=2.164V — safe margin
 *   ORP: offset=-260.471
 * ================================================================
 */

#include "thingProperties.h"
#include <math.h>
#include <OneWire.h>
#include <DallasTemperature.h>

const int PH_PIN_1  = A0;
const int ORP_PIN_1 = A1;
const int EC_PIN_1  = A2;
const int MFC_PIN_1 = A3;

#define TEMP_PIN_1 10

OneWire oneWire1(TEMP_PIN_1);
DallasTemperature tempBus1(&oneWire1);

const int PUMP_KOMBUCHA_T1 = 2;
const int PUMP_ACETATE_T1  = 4;
const int PUMP_URINE_T1    = 8;

const int RELAY_MFC_GATE = 3;
const bool RELAY_ON  = HIGH;
const bool RELAY_OFF = LOW;

const int RELAY_UNUSED_1 = 5;
const int RELAY_UNUSED_2 = 6;

const float VREF    = 3.3f;
const int   ADC_MAX = 4095;

const float PH7_TRUE = 7.00f;
const float PH4_TRUE = 4.00f;
const float PH7_V    = 1.2355f;
const float PH4_V    = 1.6335f;
const float PH_M     = (PH7_TRUE - PH4_TRUE) / (PH7_V - PH4_V);
const float PH_B     = PH7_TRUE - (PH_M * PH7_V);

const float ORP_OFFSET       = -260.471f;
const float EC_SLOPE_MSPERMV = 1.5669f;
const float EC_OFFSET_MS     = 1.1858f;

const float ML_PER_SEC_URINE_T1   = 0.663f;
const float ML_PER_SEC_ACETATE_T1 = 0.395f;

const float REACTOR_VOLUME_ML  = 875.0f;
const float HRT_H              = 12.0f;

const unsigned long DOSE_INTERVAL_MS   = 300000;
const unsigned long STATUS_INTERVAL_MS = 2000;

const float DOSE_INTERVAL_MIN  = DOSE_INTERVAL_MS / 60000.0f;
const float Q_PER_DOSE         = (REACTOR_VOLUME_ML / (HRT_H * 60.0f)) * DOSE_INTERVAL_MIN * 2.0f;
const float Q_URINE_PER_DOSE   = (REACTOR_VOLUME_ML / (HRT_H * 2.0f)) / 6.0f;
const float Q_ACETATE_PER_DOSE = (REACTOR_VOLUME_ML / (HRT_H * 2.0f)) / 6.0f;

const unsigned long SAMPLE_STEP_MS = 1000;
const int ORP_POINTS   = 5;
const int MFC_POINTS   = 5;
const int TOTAL_POINTS = ORP_POINTS + MFC_POINTS;

unsigned long lastSampleStepMs = 0;
int sampleIndex = 0;

struct SensorData {
  float pH;
  float pH_V;
  int   pH_ADC;
  float ORP_mV;
  float ORP_V;
  int   ORP_ADC;
  bool  ORP_valid;
  float EC_mS;
  float MFC_mV;
  bool  MFC_valid;
  float Temp_C;
};

unsigned long lastDoseTime   = 0;
unsigned long lastStatusTime = 0;
unsigned long doseCount      = 0;
bool          doseUrineTurn  = true;

const unsigned long CLOUD_UPDATE_INTERVAL_MS = 5000;
unsigned long lastCloudUpdateMs = 0;

float latest_pH        = 0.0f;
float latest_EC_mS     = 0.0f;
float latest_ORP_mV    = 0.0f;
float latest_MFC_mV    = 0.0f;
float latest_Temp_C    = 0.0f;
bool  latest_gateOn    = false;
float latest_Q_urine   = 0.0f;
float latest_Q_acetate = 0.0f;

float rawTo_mV(int raw) { return raw * 3300.0f / 4095.0f; }

float clamp(float v, float lo, float hi) {
  if (v < lo) return lo;
  if (v > hi) return hi;
  return v;
}

int readADC_avg(int pin, int n = 30, int delay_ms = 2) {
  long sum = 0;
  for (int i = 0; i < n; i++) { sum += analogRead(pin); delay(delay_ms); }
  return (int)(sum / n);
}

float adcToVolts(int adc) { return ((float)adc) * (VREF / (float)ADC_MAX); }

float readDS18B20(DallasTemperature& bus) {
  bus.requestTemperatures();
  float c = bus.getTempCByIndex(0);
  if (c == DEVICE_DISCONNECTED_C || c == 85.0f) return NAN;
  if (c < -55.0f || c > 125.0f) return NAN;
  return c;
}

void forceUnusedRelaysOff() {
  digitalWrite(RELAY_UNUSED_1, LOW);
  digitalWrite(RELAY_UNUSED_2, LOW);
}

void allPumpsOff() {
  digitalWrite(PUMP_URINE_T1,    LOW);
  digitalWrite(PUMP_KOMBUCHA_T1, LOW);
  digitalWrite(PUMP_ACETATE_T1,  LOW);
}

float readEC_T1_mS() {
  float voltage = adcToVolts(readADC_avg(EC_PIN_1, 30, 2));
  return EC_SLOPE_MSPERMV * voltage + EC_OFFSET_MS;
}

float readORP_T1_mV(float voltage) {
  return 1320.0f - (voltage * 1000.0f) - ORP_OFFSET;
}

SensorData readTank1Sensors(bool doORP, bool doMFC) {
  SensorData s;

  s.pH_ADC = readADC_avg(PH_PIN_1, 30, 2);
  s.pH_V   = adcToVolts(s.pH_ADC);
  s.pH     = clamp(PH_M * s.pH_V + PH_B, 0.0f, 14.0f);

  if (doORP) {
    s.ORP_ADC   = readADC_avg(ORP_PIN_1, 30, 2);
    s.ORP_V     = adcToVolts(s.ORP_ADC);
    s.ORP_mV    = readORP_T1_mV(s.ORP_V);
    s.ORP_valid = true;
  } else {
    s.ORP_ADC = 0; s.ORP_V = NAN; s.ORP_mV = NAN; s.ORP_valid = false;
  }

  s.EC_mS = readEC_T1_mS();

  if (doMFC) {
    s.MFC_mV    = rawTo_mV(analogRead(MFC_PIN_1));
    s.MFC_valid = true;
  } else {
    s.MFC_mV = NAN; s.MFC_valid = false;
  }

  s.Temp_C = readDS18B20(tempBus1);
  return s;
}

void runPump_mL(int pin, float mL, float mL_per_sec, const char* name) {
  if (mL <= 0.0f) {
    Serial.print(F("  SKIP ")); Serial.print(name); Serial.println(F(": 0.000 mL"));
    return;
  }
  float seconds = mL / mL_per_sec;
  unsigned long ms = (unsigned long)(seconds * 1000.0f);
  if (ms < 30) ms = 30;
  Serial.print(F("  RUN ")); Serial.print(name);
  Serial.print(F(": ")); Serial.print(mL, 3);
  Serial.print(F(" mL (")); Serial.print(ms); Serial.println(F(" ms)"));
  digitalWrite(pin, HIGH);
  delay(ms);
  digitalWrite(pin, LOW);
  delay(100);
}

void syncToCloud(unsigned long now) {
  cloud_pH                = latest_pH;
  cloud_EC_mS             = latest_EC_mS;
  cloud_ORP_mV            = latest_ORP_mV;
  cloud_MFC_mV            = latest_MFC_mV;
  cloud_Temp_C            = latest_Temp_C;
  cloud_gateOn            = latest_gateOn;
  cloud_stressState       = String("CONST_FLOW");
  cloud_stressCycle       = (int)doseCount;
  cloud_holdRemaining_min = 0;
  cloud_Q_urine_mL        = latest_Q_urine;
  cloud_Q_kombucha_mL     = 0.0f;
  cloud_Q_spir_mL         = latest_Q_acetate;
  cloud_HRT               = HRT_H;
  cloud_emergency         = false;
}

void printStatus(const SensorData& s, bool gateOn) {
  unsigned long sec = millis() / 1000;
  Serial.print(sec);
  Serial.print(F("s | Gate="));
  Serial.print(gateOn ? F("ON ") : F("OFF "));
  Serial.print(F("| CONST_FLOW | HRT="));
  Serial.print(HRT_H, 0);
  Serial.print(F("h | Next="));
  Serial.print(doseUrineTurn ? F("URINE") : F("ACETATE"));
  Serial.print(F(" | pH="));    Serial.print(s.pH, 2);
  Serial.print(F(" EC="));      Serial.print(s.EC_mS, 2); Serial.print(F("mS"));
  Serial.print(F(" | ORP="));
  if (s.ORP_valid) { Serial.print(s.ORP_mV, 0); Serial.print(F("mV")); }
  else             { Serial.print(F("--")); }
  Serial.print(F(" MFC="));
  if (s.MFC_valid) { Serial.print(s.MFC_mV, 0); Serial.print(F("mV")); }
  else             { Serial.print(F("--")); }
  Serial.print(F(" | Temp="));
  if (isnan(s.Temp_C)) Serial.println(F("NA"));
  else { Serial.print(s.Temp_C, 1); Serial.println(F("C")); }
}

void setup() {
  Serial.begin(115200);
  delay(1500);

  analogReadResolution(12);

  pinMode(PUMP_URINE_T1,    OUTPUT);
  pinMode(PUMP_KOMBUCHA_T1, OUTPUT);
  pinMode(PUMP_ACETATE_T1,  OUTPUT);
  allPumpsOff();

  pinMode(RELAY_UNUSED_1, OUTPUT);
  pinMode(RELAY_UNUSED_2, OUTPUT);
  forceUnusedRelaysOff();

  pinMode(RELAY_MFC_GATE, OUTPUT);
  digitalWrite(RELAY_MFC_GATE, RELAY_OFF);

  tempBus1.begin();
  tempBus1.setWaitForConversion(true);
  tempBus1.setResolution(12);

  initProperties();
  ArduinoCloud.begin(ArduinoIoTPreferredConnection);
  setDebugMessageLevel(2);
  ArduinoCloud.printDebugInfo();

  Serial.println(F("================================================"));
  Serial.println(F("  TANK 1 - CONSTANT FLOW RATE | HRT=12h"));
  Serial.print  (F("  Q_urine   = ")); Serial.print(Q_URINE_PER_DOSE, 3);   Serial.println(F(" mL/dose"));
  Serial.print  (F("  Q_acetate = ")); Serial.print(Q_ACETATE_PER_DOSE, 3); Serial.println(F(" mL/dose"));
  Serial.println(F("  pH cal: 1.2355V@pH7, 1.6335V@pH4"));
  Serial.println(F("  ORP cal: offset=-260.471"));
  Serial.println(F("================================================"));

  Serial.println(F("CSVHEADER,Time_s,SampleIdx,GateOn,DoseCount,PumpDosed,pH,EC_mS,ORP_mV,MFC_mV,Temp_C,Q_dosed_mL"));

  lastDoseTime      = millis();
  lastStatusTime    = millis();
  lastSampleStepMs  = millis();
  lastCloudUpdateMs = millis();
  sampleIndex       = 0;
  doseUrineTurn     = true;
}

void loop() {
  ArduinoCloud.update();
  forceUnusedRelaysOff();
  digitalWrite(PUMP_KOMBUCHA_T1, LOW);

  unsigned long now = millis();

  if (now - lastSampleStepMs >= SAMPLE_STEP_MS) {
    lastSampleStepMs += SAMPLE_STEP_MS;
    sampleIndex++;
    if (sampleIndex >= TOTAL_POINTS) sampleIndex = 0;
  }

  bool gateOn = (sampleIndex >= ORP_POINTS);
  digitalWrite(RELAY_MFC_GATE, gateOn ? RELAY_ON : RELAY_OFF);
  latest_gateOn = gateOn;

  if (now - lastStatusTime >= STATUS_INTERVAL_MS) {
    bool doORP = !gateOn;
    bool doMFC =  gateOn;

    SensorData s = readTank1Sensors(doORP, doMFC);

    latest_pH    = s.pH;
    latest_EC_mS = s.EC_mS;
    if (s.ORP_valid)      latest_ORP_mV = s.ORP_mV;
    if (s.MFC_valid)      latest_MFC_mV = s.MFC_mV;
    if (!isnan(s.Temp_C)) latest_Temp_C = s.Temp_C;

    printStatus(s, gateOn);

    Serial.print(F("DATA,"));
    Serial.print((unsigned long)(now / 1000));
    Serial.print(F(",")); Serial.print(sampleIndex);
    Serial.print(F(",")); Serial.print(gateOn ? 1 : 0);
    Serial.print(F(",")); Serial.print(doseCount);
    Serial.print(F(",--"));
    Serial.print(F(",")); Serial.print(s.pH, 3);
    Serial.print(F(",")); Serial.print(s.EC_mS, 3);
    Serial.print(F(","));
    if (s.ORP_valid) Serial.print(s.ORP_mV, 1); else Serial.print(F("NA"));
    Serial.print(F(","));
    if (s.MFC_valid) Serial.print(s.MFC_mV, 1); else Serial.print(F("NA"));
    Serial.print(F(","));
    if (isnan(s.Temp_C)) Serial.print(F("NA")); else Serial.print(s.Temp_C, 2);
    Serial.println(F(",0.0000"));

    lastStatusTime = now;
  }

  if (now - lastCloudUpdateMs >= CLOUD_UPDATE_INTERVAL_MS) {
    syncToCloud(now);
    lastCloudUpdateMs = now;
  }

  if (now - lastDoseTime >= DOSE_INTERVAL_MS) {
    digitalWrite(RELAY_MFC_GATE, RELAY_OFF);

    Serial.println(F(""));
    Serial.println(F("========================================"));
    Serial.print(F("======= DOSING | Dose #")); Serial.print(doseCount);
    Serial.print(F(" | ")); Serial.println(doseUrineTurn ? F("URINE") : F("ACETATE"));
    Serial.println(F("========================================"));

    float q_dosed = 0.0f;
    const char* pump_dosed = "";

    if (doseUrineTurn) {
      runPump_mL(PUMP_URINE_T1, Q_URINE_PER_DOSE, ML_PER_SEC_URINE_T1, "URINE (D8)");
      q_dosed          = Q_URINE_PER_DOSE;
      pump_dosed       = "URINE";
      latest_Q_urine   = Q_URINE_PER_DOSE;
      latest_Q_acetate = 0.0f;
    } else {
      runPump_mL(PUMP_ACETATE_T1, Q_ACETATE_PER_DOSE, ML_PER_SEC_ACETATE_T1, "ACETATE (D4)");
      q_dosed          = Q_ACETATE_PER_DOSE;
      pump_dosed       = "ACETATE";
      latest_Q_urine   = 0.0f;
      latest_Q_acetate = Q_ACETATE_PER_DOSE;
    }
    Serial.println(F("  SKIP PHOSPHORIC (D2): disabled"));
    Serial.println(F("--- DONE ---"));

    SensorData s = readTank1Sensors(true, false);
    Serial.print(F("DATA,"));
    Serial.print((unsigned long)(now / 1000));
    Serial.print(F(",")); Serial.print(sampleIndex);
    Serial.print(F(",0,"));
    Serial.print(doseCount);
    Serial.print(F(",")); Serial.print(pump_dosed);
    Serial.print(F(",")); Serial.print(s.pH, 3);
    Serial.print(F(",")); Serial.print(s.EC_mS, 3);
    Serial.print(F(",")); Serial.print(s.ORP_mV, 1);
    Serial.print(F(",NA,"));
    if (isnan(s.Temp_C)) Serial.print(F("NA")); else Serial.print(s.Temp_C, 2);
    Serial.print(F(",")); Serial.println(q_dosed, 4);

    doseUrineTurn = !doseUrineTurn;
    doseCount++;

    Serial.print(F("  Dose count: ")); Serial.println(doseCount);
    Serial.print(F("  Next pump: ")); Serial.println(doseUrineTurn ? F("URINE") : F("ACETATE"));
    Serial.println(F("========================================\n"));

    syncToCloud(now);
    ArduinoCloud.update();

    lastDoseTime = millis();
  }
}
