/*
 * ================================================================
 * APPLE JUICE IDENTIFICATION EXPERIMENT
 * Arduino GIGA R1 WiFi
 *
 * Doses apple juice only (D4 pump) for 10 minutes near pH=7.0
 * to identify b_AJ_pH for B matrix re-identification.
 *
 * SEQUENCE:
 *   IDLE  — waits until pH is between 6.8 and 7.2 then auto-starts
 *   RUN   — doses apple juice every minute for 10 minutes, no urine
 *   DONE  — stops all dosing, prints summary
 *
 * PUMPS:  D4 = Apple juice (was acetate), 1.055 mL/s
 *         D8 = Urine — NOT USED in this experiment
 *         D2 = Phosphoric — NOT USED
 *
 * DOSE SIZE: 3.0 mL per minute (conservative starting point)
 *            Change DOSE_ML_AJ below if you want more or less
 *
 * After running, upload the serial log CSV to Claude for
 * Nelder-Mead identification of b_AJ_pH.
 * ================================================================
 */

#include "thingProperties.h"
#include <math.h>
#include <OneWire.h>
#include <DallasTemperature.h>

// ── Pins ──────────────────────────────────────────────────────────────────────
#define   PH_PIN_1   A11
#define   ORP_PIN_1  A1
const int EC_PIN_1           = A2;
const int MFC_PIN_1          = A3;
const int PUMP_PHOSPHORIC_T1 = 2;
const int PUMP_AJ_T1         = 4;   // apple juice — was acetate
const int PUMP_URINE_T1      = 8;
const int RELAY_MFC_GATE     = 3;
const int RELAY_UNUSED_1     = 5;
const int RELAY_UNUSED_2     = 6;
#define   TEMP_PIN_1 10

OneWire           oneWire1(TEMP_PIN_1);
DallasTemperature tempBus1(&oneWire1);

const bool RELAY_ON  = HIGH;
const bool RELAY_OFF = LOW;

// ── ADC ───────────────────────────────────────────────────────────────────────
const float VREF    = 3.3f;
const int   ADC_MAX = 4095;

// ── pH calibration ────────────────────────────────────────────────────────────
const float PH_M = -7.551f;
const float PH_B = 15.993f;

// ── EC calibration ────────────────────────────────────────────────────────────
const float EC_SLOPE_MSPERMV = 9.006f;
const float EC_OFFSET_MS     = -5.567f;

// ── ORP calibration ───────────────────────────────────────────────────────────
const float ORP_OFFSET = -298.0f;

// ── Pump flow rate ────────────────────────────────────────────────────────────
const float ML_PER_SEC_AJ = 1.055f;   // same tubing as acetate

// ── Experiment parameters ─────────────────────────────────────────────────────
const float         DOSE_ML_AJ       = 12.0f;    // mL per minute — adjust if needed
const float         PH_START_MIN     = 6.8f;    // auto-start window low
const float         PH_START_MAX     = 7.2f;    // auto-start window high
const int           N_DOSES          = 10;       // 10 minutes
const unsigned long DOSE_INTERVAL_MS = 60000UL; // 1 dose per minute

// ── State ─────────────────────────────────────────────────────────────────────
enum Phase { IDLE, RUN, DONE };
Phase phase = IDLE;
int   doseCount = 0;

unsigned long lastDoseMs  = 0;
unsigned long lastStatusMs = 0;

const unsigned long STATUS_INTERVAL_MS = 2000UL;
const unsigned long CLOUD_INTERVAL_MS  = 5000UL;
unsigned long lastCloudMs = 0;

// ── MFC gate ──────────────────────────────────────────────────────────────────
const unsigned long SAMPLE_STEP_MS  = 1000UL;
const unsigned long RELAY_SETTLE_MS = 100UL;
const int ORP_POINTS   = 5;
const int TOTAL_POINTS = 10;
unsigned long lastSampleStepMs = 0;
int           sampleIndex      = 0;
bool          gateOn           = false;
unsigned long relaySwitchMs    = 0;
bool          relaySettled     = true;

// ── Sensor cache ──────────────────────────────────────────────────────────────
float latest_pH   = 7.0f, latest_EC  = 3.9f;
float latest_ORP  = 0.0f, latest_MFC = 0.0f;
float latest_Temp = 20.0f;
float latest_pH_V  = 0.0f, latest_EC_V  = 0.0f;
float latest_ORP_V = 0.0f, latest_MFC_V = 0.0f;
bool  pH_valid = false;

// ── Dose log (pH before each dose) ───────────────────────────────────────────
float dose_pH_log[N_DOSES];
float dose_mL_log[N_DOSES];

// =============================================================================
//  UTILITY
// =============================================================================
float adcToVolts(int adc) { return (float)adc * (VREF / (float)ADC_MAX); }

int readADC_avg(int pin, int n = 30) {
    long sum = 0;
    for (int i = 0; i < n; i++) { sum += analogRead(pin); delay(2); }
    return (int)(sum / n);
}

float readPH() {
    long sum = 0;
    for (int i = 0; i < 30; i++) { sum += analogRead(PH_PIN_1); delay(2); }
    latest_pH_V = adcToVolts((int)(sum / 30));
    float ph = PH_M * latest_pH_V + PH_B;
    if (latest_pH_V >= 3.28f || latest_pH_V < 0.1f || ph < 0.0f || ph > 14.0f) {
        pH_valid = false;
        return latest_pH;
    }
    pH_valid = true;
    return ph;
}

float readEC() {
    int raw = readADC_avg(EC_PIN_1);
    latest_EC_V = adcToVolts(raw);
    return EC_SLOPE_MSPERMV * latest_EC_V + EC_OFFSET_MS;
}

float readORP() {
    long sum = 0;
    for (int i = 0; i < 30; i++) { sum += analogRead(ORP_PIN_1); delay(2); }
    latest_ORP_V = adcToVolts((int)(sum / 30));
    return 1320.0f - latest_ORP_V * 1000.0f - ORP_OFFSET;
}

float readMFC() {
    int raw = readADC_avg(MFC_PIN_1);
    latest_MFC_V = adcToVolts(raw);
    return latest_MFC_V * 1000.0f;
}

float readTemp() {
    tempBus1.requestTemperatures();
    float c = tempBus1.getTempCByIndex(0);
    if (c == DEVICE_DISCONNECTED_C || c == 85.0f || c < -55.0f || c > 125.0f) return NAN;
    return c;
}

void doseML(int pin, float mL, float mL_per_sec, const char* name) {
    if (mL <= 0.0f) return;
    unsigned long ms = (unsigned long)((mL / mL_per_sec) * 1000.0f);
    if (ms < 30) ms = 30;
    Serial.print(F("  PUMP ")); Serial.print(name);
    Serial.print(F(": "));      Serial.print(mL, 3);
    Serial.print(F(" mL ("));   Serial.print(ms); Serial.println(F(" ms)"));
    digitalWrite(pin, HIGH); delay(ms); digitalWrite(pin, LOW); delay(100);
}

// =============================================================================
//  CLOUD SYNC
// =============================================================================
void onCloudVFAMLChange() {}

void syncCloud(const char* lbl) {
    cloud_pH          = latest_pH;
    cloud_EC_mS       = latest_EC;
    cloud_ORP_mV      = latest_ORP;
    cloud_MFC_mV      = latest_MFC;
    cloud_Temp_C      = latest_Temp;
    cloud_gateOn      = gateOn;
    cloud_Q_spir_mL   = (phase == RUN) ? DOSE_ML_AJ : 0.0f;
    cloud_Q_urine_mL  = 0.0f;
    cloud_stressState = String(lbl);
    cloud_stressCycle = doseCount;
    cloud_HRT         = 0;
    cloud_emergency   = false;
    cloud_holdRemaining_min = (phase == RUN) ? (N_DOSES - doseCount) : 0;
}

// =============================================================================
//  SETUP
// =============================================================================
void setup() {
    Serial.begin(115200); delay(1500);
    analogReadResolution(12);

    pinMode(PUMP_URINE_T1,      OUTPUT); digitalWrite(PUMP_URINE_T1,      LOW);
    pinMode(PUMP_AJ_T1,         OUTPUT); digitalWrite(PUMP_AJ_T1,         LOW);
    pinMode(PUMP_PHOSPHORIC_T1, OUTPUT); digitalWrite(PUMP_PHOSPHORIC_T1, LOW);
    pinMode(RELAY_MFC_GATE,     OUTPUT); digitalWrite(RELAY_MFC_GATE,     RELAY_OFF);
    pinMode(RELAY_UNUSED_1,     OUTPUT); digitalWrite(RELAY_UNUSED_1,     LOW);
    pinMode(RELAY_UNUSED_2,     OUTPUT); digitalWrite(RELAY_UNUSED_2,     LOW);

    tempBus1.begin();
    tempBus1.setWaitForConversion(true);
    tempBus1.setResolution(12);

    initProperties();
    ArduinoCloud.begin(ArduinoIoTPreferredConnection);
    setDebugMessageLevel(2);
    ArduinoCloud.printDebugInfo();

    unsigned long now = millis();
    lastDoseMs = lastStatusMs = lastCloudMs = lastSampleStepMs = now;

    digitalWrite(RELAY_MFC_GATE, RELAY_OFF);
    delay(200);
    latest_pH  = readPH();
    latest_EC  = readEC();
    latest_ORP = readORP();
    relaySwitchMs = now; relaySettled = true; gateOn = false;

    Serial.println(F("======================================================="));
    Serial.println(F("  APPLE JUICE IDENTIFICATION EXPERIMENT"));
    Serial.println(F("  D4 pump = Apple Juice  |  Urine/Phosphoric NOT USED"));
    Serial.print  (F("  Dose size: ")); Serial.print(DOSE_ML_AJ, 1);
    Serial.println(F(" mL per minute x 10 minutes"));
    Serial.print  (F("  Auto-starts when pH is ")); Serial.print(PH_START_MIN, 1);
    Serial.print  (F(" - ")); Serial.println(PH_START_MAX, 1);
    Serial.println(F("======================================================="));
    Serial.println(F("CSVHEADER,Time_s,Phase,Dose#,pH,EC_mS,ORP_mV,Temp_C,AJ_mL,pH_raw_V,EC_raw_V,ORP_raw_V,MFC_raw_V,pH_valid"));
    Serial.println(F("=== IDLE — waiting for pH 6.8-7.2 to auto-start ==="));
}

// =============================================================================
//  LOOP
// =============================================================================
void loop() {
    ArduinoCloud.update();
    digitalWrite(RELAY_UNUSED_1, LOW);
    digitalWrite(RELAY_UNUSED_2, LOW);
    unsigned long now = millis();

    // ── MFC gate ──────────────────────────────────────────────────────────────
    if (now - lastSampleStepMs >= SAMPLE_STEP_MS) {
        lastSampleStepMs += SAMPLE_STEP_MS;
        if (++sampleIndex >= TOTAL_POINTS) sampleIndex = 0;
        bool newGate = (sampleIndex >= ORP_POINTS);
        if (newGate != gateOn) {
            gateOn = newGate;
            digitalWrite(RELAY_MFC_GATE, gateOn ? RELAY_ON : RELAY_OFF);
            relaySwitchMs = now; relaySettled = false;
        }
    }
    if (!relaySettled && (now - relaySwitchMs >= RELAY_SETTLE_MS))
        relaySettled = true;

    // ── Sensor read + serial log ───────────────────────────────────────────────
    if (now - lastStatusMs >= STATUS_INTERVAL_MS) {
        float EC  = readEC();
        float Tmp = readTemp();
        latest_EC = EC;
        if (!isnan(Tmp)) latest_Temp = Tmp;
        if (!gateOn && relaySettled) {
            latest_pH  = readPH();
            latest_ORP = readORP();
        }
        if (gateOn && relaySettled) latest_MFC = readMFC();

        const char* lbl = (phase==IDLE) ? "IDLE" :
                          (phase==RUN)  ? "RUN"  : "DONE";

        Serial.print(F("DATA,"));  Serial.print(now/1000);
        Serial.print(F(","));      Serial.print(lbl);
        Serial.print(F(","));      Serial.print(doseCount);
        Serial.print(F(","));      Serial.print(latest_pH,    3);
        Serial.print(F(","));      Serial.print(latest_EC,    3);
        Serial.print(F(","));      Serial.print(latest_ORP,   1);
        Serial.print(F(","));
        if (isnan(Tmp)) Serial.print(F("NA")); else Serial.print(Tmp, 2);
        Serial.print(F(","));
        Serial.print((phase==RUN) ? DOSE_ML_AJ : 0.0f, 3);
        Serial.print(F(","));      Serial.print(latest_pH_V,  4);
        Serial.print(F(","));      Serial.print(latest_EC_V,  4);
        Serial.print(F(","));      Serial.print(latest_ORP_V, 4);
        Serial.print(F(","));      Serial.print(latest_MFC_V, 4);
        Serial.print(F(","));      Serial.println(pH_valid ? F("1") : F("0"));
        lastStatusMs = now;
    }

    // ── Cloud sync ────────────────────────────────────────────────────────────
    if (now - lastCloudMs >= CLOUD_INTERVAL_MS) {
        const char* lbl = (phase==IDLE) ? "IDLE" :
                          (phase==RUN)  ? "RUN"  : "DONE";
        syncCloud(lbl);
        lastCloudMs = now;
    }

    // ── IDLE — wait for pH in window ──────────────────────────────────────────
    if (phase == IDLE) {
        if (pH_valid && latest_pH >= PH_START_MIN && latest_pH <= PH_START_MAX) {
            phase = RUN;
            doseCount = 0;
            lastDoseMs = now;
            Serial.print(F("=== pH=")); Serial.print(latest_pH, 3);
            Serial.println(F(" in window -> STARTING APPLE JUICE ID EXPERIMENT ==="));
        }
        return;
    }

    // ── DONE ──────────────────────────────────────────────────────────────────
    if (phase == DONE) {
        // Just keep logging, nothing to dose
        return;
    }

    // ── RUN — dose every minute ───────────────────────────────────────────────
    if (phase == RUN) {
        if (now - lastDoseMs >= DOSE_INTERVAL_MS) {
            lastDoseMs = now;

            // Log pH before dose
            dose_pH_log[doseCount] = latest_pH;
            dose_mL_log[doseCount] = DOSE_ML_AJ;

            Serial.print(F("  [DOSE ")); Serial.print(doseCount+1);
            Serial.print(F("/")); Serial.print(N_DOSES);
            Serial.print(F("]  pH_before=")); Serial.print(latest_pH, 3);
            Serial.print(F("  EC="));        Serial.print(latest_EC,  3);
            Serial.print(F("  dosing "));    Serial.print(DOSE_ML_AJ, 2);
            Serial.println(F(" mL AJ"));

            digitalWrite(RELAY_MFC_GATE, RELAY_OFF);
            delay(200);
            doseML(PUMP_AJ_T1, DOSE_ML_AJ, ML_PER_SEC_AJ, "APPLE_JUICE");

            doseCount++;

            if (doseCount >= N_DOSES) {
                phase = DONE;
                Serial.println(F("======================================================="));
                Serial.println(F("  EXPERIMENT COMPLETE — upload serial log to Claude"));
                Serial.println(F("  for Nelder-Mead identification of b_AJ_pH"));
                Serial.println(F("======================================================="));
                Serial.println(F("DOSE SUMMARY:"));
                for (int i = 0; i < N_DOSES; i++) {
                    Serial.print(F("  Dose ")); Serial.print(i+1);
                    Serial.print(F(": pH_before=")); Serial.print(dose_pH_log[i], 3);
                    Serial.print(F("  mL=")); Serial.println(dose_mL_log[i], 2);
                }
            }
        }
        return;
    }
}
