    "# Pump bounds — single total flow constraint\n",
    "TOTAL_LB = 0.025318 + 0.025318   # mL/step total (HRT=12h lower bound)\n",
    "TOTAL_UB = 3.65     + 3.65         # mL/step total (0.730 mL/s per pump upper bound)\n",
    "U_LB = np.array([TOTAL_LB/2, TOTAL_LB/2])\n",
