    "print(f\"Setpoint: VFA={x_sp[0]}  EC={x_sp[1]}  pH={x_sp[2]}\")\n",
    "print(f\"Total LB: {TOTAL_LB/DT*60:.3f} mL/min  |  Total UB: {TOTAL_UB/DT*60:.1f} mL/min\")"
