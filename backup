/*
 * ================================================================
 * ANAEROBIC DIGESTER - TANK 1 ONLY (SINGLE INPUT MODE) + MFC GATE
 * Arduino GIGA R1
 * ================================================================
 *
 * TANK 1 PUMPS (UNCHANGED):
 *   D7 = URINE
 *   D2 = KOMBUCHA (wine)
 *   D4 = SPIRULINA+FeOx+Molasses
 *
 * MFC ISOLATION / GATE RELAY:
 *   D3 = RELAY 1 (per your relay-sequencer mapping: Relay=1 -> D3)
 *
 * DISABLED/UNUSED RELAY CHANNELS (HARD OFF):
 *   D5, D6 forced LOW continuously
 *   (D3 is NOT forced LOW because it's the MFC gate)
 *
 * SENSORS (TANK 1):
 *   A0 = pH
 *   A1 = ORP (Grove 501Z)
 *   A2 = EC
 *   A3 = MFC (ADC read only when gate is ON)
 *   D10 = Temperature (DS18B20)
 *
 * MFC/ORP TIMING:
 *   30s cycle:
 *     - first 25s: MFC gate OFF (isolated), ORP measured, MFC skipped
 *     - last  5s: MFC gate ON  (connected), MFC measured, ORP skipped
 *
 * STATUS:
 *   Prints + CSV line every 2 seconds.
 *
 * DOSING:
 *   Still doses every 60 seconds (blocking).
 *   During dosing, MFC gate forced OFF for stability.
 * ================================================================
 */

#include <math.h>
#include <OneWire.h>
#include <DallasTemperature.h>

// ================================================================
// SENSOR PINS (TANK 1 ONLY)
// ================================================================
const int PH_PIN_1  = A0;
const int ORP_PIN_1 = A1;
const int EC_PIN_1  = A2;
const int MFC_PIN_1 = A3;

#define TEMP_PIN_1 10

OneWire oneWire1(TEMP_PIN_1);
DallasTemperature tempBus1(&oneWire1);

// ================================================================
// PUMP PINS (TANK 1 ONLY) - UNCHANGED
// ================================================================
const int PUMP_KOMBUCHA_T1 = 2;  // D2
const int PUMP_SPIRFEOX_T1 = 4;  // D4
const int PUMP_URINE_T1    = 7;  // D7

// ================================================================
// MFC GATE RELAY (Tank 1)
// ================================================================
const int RELAY_MFC_GATE = 3; // D3

// Many relay boards are ACTIVE-LOW. If your relay LED/click happens
// when pin is LOW, flip these:
const bool RELAY_ON  = HIGH;
const bool RELAY_OFF = LOW;

// ================================================================
// DISABLED/UNUSED RELAYS (HARD OFF)
// ================================================================
const int RELAY_UNUSED_1 = 5; // D5
const int RELAY_UNUSED_2 = 6; // D6

// ================================================================
// ADC / VOLTAGE SETTINGS
// ================================================================
const float VREF    = 3.3f;
const int   ADC_MAX = 4095;

// ================================================================
// pH 2-POINT CALIBRATION (VOLTAGE DOMAIN)
// ================================================================
const float PH7_TRUE = 7.00f;
const float PH4_TRUE = 4.00f;

const float PH7_V = 1.3299f;
const float PH4_V = 1.7746f;

// pH = PH_M*V + PH_B
const float PH_M = (PH7_TRUE - PH4_TRUE) / (PH7_V - PH4_V);
const float PH_B = PH7_TRUE - (PH_M * PH7_V);

// ================================================================
// ORP CALIBRATION - GROVE 501Z
// ORP = 1320 - voltage_mV - OFFSET
// ================================================================
const float ORP_OFFSET = -294.5f;

// ================================================================
// EC CALIBRATION
// ================================================================
const float EC_SLOPE_MSPERMV = 0.00864f;
const float EC_OFFSET_MS     = 0.033f;
const float EC1_A = 0.83945827233f;
const float EC1_C = -2.25543265007f;

// ================================================================
// PUMP CALIBRATION (mL per second)
// ================================================================
const float ML_PER_SEC_URINE_T1    = 0.663f;
const float ML_PER_SEC_KOMBUCHA_T1 = 0.730f;
const float ML_PER_SEC_SPIRFEOX_T1 = 0.395f;

// ================================================================
// REACTOR CONFIG
// ================================================================
const float REACTOR_VOLUME_ML = 875.0f;

const float HRT_BASE_HR      = 12.0f;
const float HRT_EMERGENCY_HR = 3.0f;

const unsigned long DOSE_INTERVAL_MS   = 60000; // 60s
const unsigned long STATUS_INTERVAL_MS = 2000;  // 2s

// ================================================================
// pH LIMITS - SINGLE INPUT MODE
// ================================================================
const float PH_MIN_EMERGENCY = 6.4f;
const float PH_MAX_EMERGENCY = 7.6f;

const float PH_URINE_MAX     = 6.7f;
const float PH_FEOX_MAX      = 7.3f;

// ================================================================
// MFC/ORP CYCLE TIMING
// ================================================================
const unsigned long CYCLE_MS      = 30000; // 30s cycle
const unsigned long MFC_WINDOW_MS = 5000;  // last 5s of each cycle
unsigned long cycleStartMs = 0;

// ================================================================
// DATA STRUCTURES
// ================================================================
struct SensorData {
  float pH;
  float pH_V;
  int   pH_ADC;

  float ORP_mV;
  float ORP_V;
  int   ORP_ADC;
  bool  ORP_valid;

  float EC_mS;

  float MFC_mV;
  bool  MFC_valid;

  float Temp_C;
};

struct DoseVolumes {
  float Q_urine_mL;
  float Q_kombucha_mL;
  float Q_spir_mL;
  float Q_total_mL;
  float HRT;
  bool  emergency;
};

// ================================================================
// TIMING STATE
// ================================================================
unsigned long lastDoseTime   = 0;
unsigned long lastStatusTime = 0;
unsigned long doseCount      = 0;

// ================================================================
// HELPERS
// ================================================================
float rawTo_mV(int raw) { return raw * 3300.0f / 4095.0f; }

float clamp(float v, float lo, float hi) {
  if (v < lo) return lo;
  if (v > hi) return hi;
  return v;
}

int readADC_avg(int pin, int n = 30, int delay_ms = 2) {
  long sum = 0;
  for (int i = 0; i < n; i++) {
    sum += analogRead(pin);
    delay(delay_ms);
  }
  return (int)(sum / n);
}

float adcToVolts(int adc) {
  return ((float)adc) * (VREF / (float)ADC_MAX);
}

float readDS18B20(DallasTemperature& bus) {
  bus.requestTemperatures();
  float c = bus.getTempCByIndex(0);
  if (c == DEVICE_DISCONNECTED_C || c == 85.0f) return NAN;
  if (c < -55.0f || c > 125.0f) return NAN;
  return c;
}

// ================================================================
// HARD OFF SAFETY
// ================================================================
void forceUnusedRelaysOff() {
  digitalWrite(RELAY_UNUSED_1, LOW);
  digitalWrite(RELAY_UNUSED_2, LOW);
}

void allPumpsOff() {
  digitalWrite(PUMP_URINE_T1, LOW);
  digitalWrite(PUMP_KOMBUCHA_T1, LOW);
  digitalWrite(PUMP_SPIRFEOX_T1, LOW);
}

// ================================================================
// SENSOR READS (TANK 1)
// ================================================================
float readEC_T1_mS() {
  float ec_meas = EC_SLOPE_MSPERMV * rawTo_mV(analogRead(EC_PIN_1)) + EC_OFFSET_MS;
  return EC1_A * ec_meas + EC1_C;
}

float readMFC_T1_mV_single() {
  return rawTo_mV(analogRead(MFC_PIN_1));
}

float readORP_T1_mV(float voltage) {
  float voltage_mV = voltage * 1000.0f;
  return 1320.0f - voltage_mV - ORP_OFFSET;
}

SensorData readTank1Sensors(bool doORP, bool doMFC) {
  SensorData s;

  // pH
  s.pH_ADC = readADC_avg(PH_PIN_1, 30, 2);
  s.pH_V   = adcToVolts(s.pH_ADC);
  s.pH     = clamp(PH_M * s.pH_V + PH_B, 0.0f, 14.0f);

  // ORP
  if (doORP) {
    s.ORP_ADC = readADC_avg(ORP_PIN_1, 30, 2);
    s.ORP_V   = adcToVolts(s.ORP_ADC);
    s.ORP_mV  = readORP_T1_mV(s.ORP_V);
    s.ORP_valid = true;
  } else {
    s.ORP_ADC = 0;
    s.ORP_V   = NAN;
    s.ORP_mV  = NAN;
    s.ORP_valid = false;
  }

  // EC
  s.EC_mS = readEC_T1_mS();

  // MFC
  if (doMFC) {
    s.MFC_mV = readMFC_T1_mV_single();
    s.MFC_valid = true;
  } else {
    s.MFC_mV = NAN;
    s.MFC_valid = false;
  }

  // Temp
  s.Temp_C = readDS18B20(tempBus1);

  return s;
}

// ================================================================
// DOSE CALCULATION - SINGLE INPUT MODE
// ================================================================
DoseVolumes calculateDose(const SensorData& s) {
  DoseVolumes d;

  d.emergency = (s.pH < PH_MIN_EMERGENCY || s.pH > PH_MAX_EMERGENCY);
  d.HRT = d.emergency ? HRT_EMERGENCY_HR : HRT_BASE_HR;

  float Q_base = REACTOR_VOLUME_ML / (d.HRT * 60.0f);

  d.Q_urine_mL    = 0.0f;
  d.Q_kombucha_mL = 0.0f;
  d.Q_spir_mL     = 0.0f;

  if (s.pH < PH_MIN_EMERGENCY)       d.Q_urine_mL = Q_base;
  else if (s.pH < PH_URINE_MAX)      d.Q_urine_mL = Q_base;
  else if (s.pH <= PH_FEOX_MAX)      d.Q_spir_mL  = Q_base;
  else                               d.Q_kombucha_mL = Q_base;

  d.Q_total_mL = d.Q_urine_mL + d.Q_kombucha_mL + d.Q_spir_mL;
  return d;
}

// ================================================================
// PUMP RUNNER (blocking)
// ================================================================
void runPump_mL(int pin, float mL, float mL_per_sec, const char* name) {
  if (mL <= 0.0f) {
    Serial.print(F("  SKIP "));
    Serial.print(name);
    Serial.println(F(": 0.000 mL"));
    return;
  }

  float seconds = mL / mL_per_sec;
  unsigned long ms = (unsigned long)(seconds * 1000.0f);
  if (ms < 30) ms = 30;

  Serial.print(F("  RUN "));
  Serial.print(name);
  Serial.print(F(": "));
  Serial.print(mL, 3);
  Serial.print(F(" mL ("));
  Serial.print(ms);
  Serial.println(F(" ms)"));

  digitalWrite(pin, HIGH);
  delay(ms);
  digitalWrite(pin, LOW);
  delay(100);
}

void executeDose(const DoseVolumes& d) {
  Serial.println(F("--- TANK 1 DOSING ---"));
  runPump_mL(PUMP_URINE_T1,    d.Q_urine_mL,    ML_PER_SEC_URINE_T1,    "URINE (D7)");
  runPump_mL(PUMP_KOMBUCHA_T1, d.Q_kombucha_mL, ML_PER_SEC_KOMBUCHA_T1, "KOMBUCHA (D2)");
  runPump_mL(PUMP_SPIRFEOX_T1, d.Q_spir_mL,     ML_PER_SEC_SPIRFEOX_T1, "SPIR+Fe+Mol (D4)");
  Serial.println(F("--- DONE ---"));
}

// ================================================================
// STATUS PRINT
// ================================================================
const char* getPHMode(float pH) {
  if (pH < PH_MIN_EMERGENCY) return "EMERG_LOW(urine)";
  if (pH < PH_URINE_MAX)     return "LOW(urine)";
  if (pH <= PH_FEOX_MAX)     return "STABLE(FeOx)";
  if (pH <= PH_MAX_EMERGENCY) return "HIGH(kombucha)";
  return "EMERG_HIGH(kombucha)";
}

void printStatus(const SensorData& s, bool inMfcWindow, float hrt, bool emergency) {
  unsigned long sec = millis() / 1000;

  Serial.print(sec);
  Serial.print(F("s | pH="));
  Serial.print(s.pH, 2);
  Serial.print(F(" ("));
  Serial.print(getPHMode(s.pH));
  Serial.print(F(") "));

  Serial.print(F("| EC="));
  Serial.print(s.EC_mS, 2);
  Serial.print(F("mS/cm "));

  if (!inMfcWindow) {
    Serial.print(F("| ORP="));
    if (s.ORP_valid) { Serial.print(s.ORP_mV, 0); Serial.print(F("mV ")); }
    else             { Serial.print(F("NA ")); }
    Serial.print(F("| MFC=SKIP "));
  } else {
    Serial.print(F("| ORP=SKIP "));
    Serial.print(F("| MFC="));
    if (s.MFC_valid) { Serial.print(s.MFC_mV, 0); Serial.print(F("mV ")); }
    else             { Serial.print(F("NA ")); }
  }

  Serial.print(F("| HRT="));
  Serial.print(hrt, 1);
  Serial.print(emergency ? F(" [EMERGENCY] ") : F(" [BASE] "));

  Serial.print(F("| Gate="));
  Serial.print(inMfcWindow ? F("ON ") : F("OFF "));

  Serial.print(F("| Temp="));
  if (isnan(s.Temp_C)) Serial.println(F("NA"));
  else { Serial.print(s.Temp_C, 1); Serial.println(F("C")); }
}

// ================================================================
// SETUP
// ================================================================
void setup() {
  Serial.begin(115200);
  while (!Serial) {}
  delay(200);

  analogReadResolution(12);

  // Pumps
  pinMode(PUMP_URINE_T1, OUTPUT);
  pinMode(PUMP_KOMBUCHA_T1, OUTPUT);
  pinMode(PUMP_SPIRFEOX_T1, OUTPUT);
  allPumpsOff();

  // Unused relays hard-off
  pinMode(RELAY_UNUSED_1, OUTPUT);
  pinMode(RELAY_UNUSED_2, OUTPUT);
  forceUnusedRelaysOff();

  // MFC gate relay
  pinMode(RELAY_MFC_GATE, OUTPUT);
  digitalWrite(RELAY_MFC_GATE, RELAY_OFF);

  // Temp
  tempBus1.begin();
  tempBus1.setWaitForConversion(true);
  tempBus1.setResolution(12);

  Serial.println(F(""));
  Serial.println(F("================================================"));
  Serial.println(F("  TANK 1 ONLY - SINGLE INPUT MODE + MFC GATE"));
  Serial.println(F("  Pumps: URINE=D7, KOMBUCHA=D2, SPIR+Fe=D4"));
  Serial.println(F("  MFC Gate Relay: D3 (Relay=1 in your mapping)"));
  Serial.println(F("  Cycle: 25s ORP (gate OFF) + 5s MFC (gate ON, ORP skipped)"));
  Serial.println(F("  Status+CSV every 2s | Dose every 60s"));
  Serial.println(F("================================================"));
  Serial.println(F(""));

  Serial.println(F("CSVHEADER,Time_s,pH,EC_mS,ORP_mV,MFC_mV,Temp_C,GateOn,Mode,HRT,Emergency,Q_urine,Q_kombucha,Q_spir"));

  lastDoseTime   = millis();
  lastStatusTime = millis();
  cycleStartMs   = millis();
}

// ================================================================
// MAIN LOOP
// ================================================================
void loop() {
  forceUnusedRelaysOff();

  unsigned long now = millis();

  // Determine where we are in the 30s cycle
  unsigned long cyclePos = (now - cycleStartMs) % CYCLE_MS;
  bool inMfcWindow = (cyclePos >= (CYCLE_MS - MFC_WINDOW_MS));

  // Gate control
  digitalWrite(RELAY_MFC_GATE, inMfcWindow ? RELAY_ON : RELAY_OFF);

  // Status every 2 seconds
  if (now - lastStatusTime >= STATUS_INTERVAL_MS) {
    bool doORP = !inMfcWindow;
    bool doMFC = inMfcWindow;

    SensorData s = readTank1Sensors(doORP, doMFC);

    bool emergency = (s.pH < PH_MIN_EMERGENCY || s.pH > PH_MAX_EMERGENCY);
    float hrt = emergency ? HRT_EMERGENCY_HR : HRT_BASE_HR;

    printStatus(s, inMfcWindow, hrt, emergency);

    DoseVolumes preview = calculateDose(s);

    // CSV
    Serial.print(F("DATA,"));
    Serial.print((unsigned long)(now / 1000));
    Serial.print(F(","));
    Serial.print(s.pH, 3);
    Serial.print(F(","));
    Serial.print(s.EC_mS, 3);
    Serial.print(F(","));
    if (s.ORP_valid) Serial.print(s.ORP_mV, 1); else Serial.print(F("NA"));
    Serial.print(F(","));
    if (s.MFC_valid) Serial.print(s.MFC_mV, 1); else Serial.print(F("NA"));
    Serial.print(F(","));
    if (isnan(s.Temp_C)) Serial.print(F("NA")); else Serial.print(s.Temp_C, 2);
    Serial.print(F(","));
    Serial.print(inMfcWindow ? 1 : 0);
    Serial.print(F(","));
    Serial.print(getPHMode(s.pH));
    Serial.print(F(","));
    Serial.print(hrt, 1);
    Serial.print(F(","));
    Serial.print(emergency ? 1 : 0);
    Serial.print(F(","));
    Serial.print(preview.Q_urine_mL, 4);
    Serial.print(F(","));
    Serial.print(preview.Q_kombucha_mL, 4);
    Serial.print(F(","));
    Serial.println(preview.Q_spir_mL, 4);

    lastStatusTime = now;
  }

  // Dose every 60 seconds
  if (now - lastDoseTime >= DOSE_INTERVAL_MS) {
    // Force gate OFF during dosing
    digitalWrite(RELAY_MFC_GATE, RELAY_OFF);

    Serial.println(F(""));
    Serial.println(F("========================================"));
    Serial.println(F("======= TANK 1 DOSING CYCLE ============"));
    Serial.println(F("========================================"));

    // During dosing-cycle sensor snapshot: respect timing window for ORP
    unsigned long cyclePos2 = (millis() - cycleStartMs) % CYCLE_MS;
    bool inMfcWindow2 = (cyclePos2 >= (CYCLE_MS - MFC_WINDOW_MS));
    SensorData s = readTank1Sensors(!inMfcWindow2, false); // ORP only if not in MFC window
    DoseVolumes d = calculateDose(s);

    Serial.print(F("pH: "));
    Serial.print(s.pH, 3);
    Serial.print(F(" | ORP: "));
    if (s.ORP_valid) { Serial.print(s.ORP_mV, 0); Serial.print(F("mV")); }
    else             { Serial.print(F("SKIP")); }
    Serial.print(F(" | Mode: "));
    Serial.print(getPHMode(s.pH));
    Serial.print(F(" | HRT="));
    Serial.print(d.HRT, 1);
    Serial.print(F(" hr | emergency="));
    Serial.println(d.emergency ? F("YES") : F("NO"));

    Serial.print(F("Doses (mL): urine="));
    Serial.print(d.Q_urine_mL, 4);
    Serial.print(F(" kombucha="));
    Serial.print(d.Q_kombucha_mL, 4);
    Serial.print(F(" spir="));
    Serial.print(d.Q_spir_mL, 4);
    Serial.print(F(" total="));
    Serial.println(d.Q_total_mL, 4);

    executeDose(d);

    doseCount++;
    Serial.print(F("Dose count: "));
    Serial.println(doseCount);
    Serial.println(F("========================================"));
    Serial.println(F(""));

    lastDoseTime = millis();
  }
}
